{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"api,web\" -c \"blue,green\" \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/taxi-fleet dev\"",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:web": "pnpm --filter @workspace/taxi-fleet dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "*",
    "@rollup/rollup-win32-arm64-msvc": "*",
    "@rollup/rollup-linux-x64-gnu": "*",
    "@rollup/rollup-darwin-x64": "*",
    "@rollup/rollup-darwin-arm64": "*",
    "lightningcss-win32-x64-msvc": "*",
    "lightningcss-win32-arm64-msvc": "*",
    "lightningcss-linux-x64-gnu": "*",
    "lightningcss-darwin-x64": "*",
    "lightningcss-darwin-arm64": "*",
    "@tailwindcss/oxide-win32-x64-msvc": "*",
    "@tailwindcss/oxide-win32-arm64-msvc": "*",
    "@tailwindcss/oxide-linux-x64-gnu": "*",
    "@tailwindcss/oxide-darwin-x64": "*",
    "@tailwindcss/oxide-darwin-arm64": "*",
    "@esbuild/win32-x64": "*",
    "@esbuild/win32-arm64": "*",
    "@esbuild/linux-x64": "*",
    "@esbuild/darwin-x64": "*",
    "@esbuild/darwin-arm64": "*"
  }
}
